# Copy to .env.local and fill in your provider credentials.
# Keys never reach the browser — the frontend calls /api/image/* only.

# Background removal (remove.bg-compatible: multipart `image_file`, X-Api-Key header)
REMOVE_BG_API_URL=https://api.remove.bg/v1.0/removebg
REMOVE_BG_API_KEY=

# Image upscaling (same contract; adjust lib/server/imageProxy.ts if your provider differs)
UPSCALE_API_URL=
UPSCALE_API_KEY=
